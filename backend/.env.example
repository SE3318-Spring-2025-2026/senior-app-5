# Backend configuration
MONGODB_URI=mongodb://localhost:27017/senior-app
PORT=3001

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-strong-random-string
JWT_ACCESS_EXPIRES_IN=15m

# GitHub OAuth
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must match the frontend integrations page (e.g. http://localhost:5173/integrations)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
