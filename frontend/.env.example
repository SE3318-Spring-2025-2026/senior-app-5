# Frontend API Configuration
VITE_API_BASE_URL=http://localhost:3001/api/v1

# GitHub OAuth (browser-side client ID; the secret stays on the backend)
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must be the integrations page, e.g. http://localhost:5173/integrations
VITE_GITHUB_CLIENT_ID=

# Space-separated GitHub OAuth scopes. Defaults below cover:
#   read:user     identify the linked user
#   read:project  read GitHub Projects v2 (story points / custom fields)
#   repo          read issues + project items in private repos
#                 → swap with `public_repo` if all linked repos are public
#   read:org      list an organization's Projects v2 (only needed for org-owned projects)
# Org-owned + public repos: read:user read:project read:org public_repo
# User-owned + private repos: read:user read:project repo
VITE_GITHUB_OAUTH_SCOPES=read:user read:project repo
