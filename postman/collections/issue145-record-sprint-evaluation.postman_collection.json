    {
      "name": "4) GET /sprint-evaluations/{evaluationId}",
      "item": [
        {
          "name": "200 - Professor gets own SCRUM evaluation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{professorToken}}"
              },
              {
