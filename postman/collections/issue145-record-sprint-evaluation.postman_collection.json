            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{advisorOwnedGroupId}}\",\n  \"sprintId\": \"{{sprintId}}\",\n  \"evaluationType\": \"SCRUM\",\n  \"responses\": [\n    {\n      \"questionId\": \"{{scrumQuestionOneId}}\",\n      \"softGrade\": \"A\"\n    },\n    {\n      \"questionId\": \"{{scrumQuestionTwoId}}\",\n      \"softGrade\": \"B\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/sprint-evaluations"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('SCRUM evaluation contract is returned', function () {",
                  "  pm.expect(body).to.have.property('evaluationId').that.is.a('string');",
                  "  pm.expect(body).to.have.property('groupId', pm.variables.get('advisorOwnedGroupId'));",
                  "  pm.expect(body).to.have.property('sprintId', pm.variables.get('sprintId'));",
                  "  pm.expect(body).to.have.property('evaluationType', 'SCRUM');",
                  "  pm.expect(body).to.have.property('rubricId', '44444444-4444-4444-4444-444444444441');",
                  "  pm.expect(body).to.have.property('averageScore', 88);",
                  "  pm.expect(body).to.have.property('status', 'SUBMITTED');",
                  "  pm.expect(body).to.have.property('createdAt');",
                  "  pm.expect(body).to.have.property('updatedAt');",
                  "  pm.expect(body.responses).to.be.an('array').with.lengthOf(2);",
                  "});",
                  "pm.environment.set('createdScrumEvaluationId', body.evaluationId);"
                ]
              }
            }
          ]
        },
