  "item": [
    {
      "name": "1) Authentication",
      "item": [
        {
          "name": "Login Professor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{professorEmail}}\",\n  \"password\": \"{{professorPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Professor token is returned', function () {",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.be.empty;",
                  "});",
                  "pm.environment.set('professorToken', body.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Coordinator",
          "request": {
