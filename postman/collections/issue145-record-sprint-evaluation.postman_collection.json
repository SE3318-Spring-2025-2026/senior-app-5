    {
      "name": "2) Schedule Control",
      "item": [
        {
          "name": "Open SPRINT Window",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{coordinatorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-correlation-id",
                "value": "issue145-schedule-open"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phase\": \"SPRINT\",\n  \"startDatetime\": \"2020-01-01T00:00:00.000Z\",\n  \"endDatetime\": \"2100-01-01T00:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/schedules"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('SPRINT schedule was created', function () {",
                  "  pm.expect(body).to.have.property('phase', 'SPRINT');",
                  "  pm.expect(body).to.have.property('scheduleId');",
                  "  pm.expect(body).to.have.property('startDatetime');",
                  "  pm.expect(body).to.have.property('endDatetime');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Active SPRINT Window",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{coordinatorToken}}"
              },
              {
                "key": "x-correlation-id",
                "value": "issue145-schedule-active"
              }
            ],
            "url": "{{baseUrl}}/schedules/active?phase=SPRINT"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('SPRINT window is open', function () {",
                  "  pm.expect(body).to.have.property('phase', 'SPRINT');",
                  "  pm.expect(body).to.have.property('isOpen', true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
