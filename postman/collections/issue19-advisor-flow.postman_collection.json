              "pm.environment.set('studentToken', body.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "4) List Advisors and Capture advisorId (200)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teamLeaderToken}}"
          },
          {
            "key": "x-correlation-id",
            "value": "issue19-list-advisors-001"
          }
        ],
        "url": "{{baseUrl}}/advisors?page=1&limit=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "const body = pm.response.json();",
              "pm.expect(body.data).to.be.an('array').that.is.not.empty;",
              "const advisor = body.data.find(function (item) {",
              "  return item.role === 'ADVISOR';",
              "}) || body.data[0];",
              "pm.expect(advisor.advisorId).to.be.a('string');",
              "pm.environment.set('advisorId', advisor.advisorId);"
            ]
          }
        }
      ]
    },
    {
      "name": "5) Set Open Advisor Selection Schedule (201)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{coordinatorToken}}"
          },
          {
            "key": "x-correlation-id",
            "value": "issue19-set-open-schedule-001"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phase\": \"ADVISOR_SELECTION\",\n  \"startDatetime\": \"2026-01-01T00:00:00.000Z\",\n  \"endDatetime\": \"2099-01-01T00:00:00.000Z\"\n}"
        },
        "url": "{{baseUrl}}/schedules"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(201);",
              "const body = pm.response.json();",
              "pm.expect(body.phase).to.eql('ADVISOR_SELECTION');",
              "pm.expect(body.scheduleId).to.be.a('string');",
              "pm.environment.set('scheduleId', body.scheduleId);"
            ]
          }
        }
      ]
    },
    {
      "name": "6) Get Active Advisor Selection Schedule (200)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teamLeaderToken}}"
          },
          {
            "key": "x-correlation-id",
            "value": "issue19-get-active-schedule-001"
          }
        ],
        "url": "{{baseUrl}}/schedules/active?phase=ADVISOR_SELECTION"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "const body = pm.response.json();",
              "pm.expect(body.phase).to.eql('ADVISOR_SELECTION');",
              "pm.expect(body.isOpen).to.eql(true);"
            ]
          }
        }
      ]
    },
    {
      "name": "7) Submit Advisor Request (201)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{teamLeaderToken}}"
          },
          {
            "key": "x-correlation-id",
            "value": "issue19-submit-request-001"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestedAdvisorId\": \"{{advisorId}}\"\n}"
        },
        "url": "{{baseUrl}}/requests"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(201);",
              "const body = pm.response.json();",
              "pm.expect(body.status).to.eql('PENDING');",
              "pm.expect(body.requestedAdvisorId).to.eql(pm.environment.get('advisorId'));",
              "pm.expect(body.requestId).to.be.a('string');"
            ]
          }
        }
      ]
    },
