              "pm.expect(body.accessToken).to.be.a('string');",
              "pm.environment.set('coordinatorToken', body.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Login Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
