              },
              {
                "key": "Authorization",
                "value": "Bearer {{professorToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"INVALID_VALUE\"\n}"
            },
            "url": "{{baseUrl}}/requests/{{requestIdPending}}/decision"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('✗ Status is 400 Bad Request (Invalid Decision Enum)', function () {",
                  "  pm.expect(pm.response.code).to.equal(400);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "✗ Invalid UUID Format - Should Return 400",
          "request": {
